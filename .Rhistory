library(readxl)
library(ggplot2)
library(ggrepel)
library(scales)
library(patchwork)
# --- Panel A: Academic Advantage ---
raa <- read_excel("figures/Green_Revealed_XXXX_Advantage/Green_Revealed_Academic_Advantage/final_dataset_RAA2.xlsx")
raa <- raa[!is.na(raa$log_average_gdppp) & !is.na(raa$SRCA), ]
ols_fit <- lm(log_average_gdppp ~ SRCA, data = raa)
pred <- predict(ols_fit, newdata = raa, interval = "confidence")
raa$fitted   <- pred[, "fit"]
raa$ci_lower <- pred[, "lwr"]
raa$ci_upper <- pred[, "upr"]
quintile_levels <- c("Very Low", "Low", "Medium", "High", "Very High")
thresholds <- tapply(raa$share_green_thresholds, raa$share_green_quintiles, max)
thresholds <- thresholds[quintile_levels]
size_labels <- paste0(quintile_levels, " (\u2264 ", round(thresholds), ")")
raa$size_label <- factor(
paste0(raa$share_green_quintiles, " (\u2264 ", round(thresholds[as.character(raa$share_green_quintiles)]), ")"),
levels = size_labels
)
raa <- raa[order(raa$marker_size), ]
# --- Panel B: Technological Advantage ---
rta <- read.csv("figures/Green_Revealed_XXXX_Advantage/Green_Revealed_Technological_Advantage/Green technology.csv",
check.names = FALSE)
rta <- rta[!is.na(rta[["Log Average GDP per capita, PPP"]]) &
!is.na(rta[["Green Symmetric Revealed Technological Advantage (RTA)"]]), ]
ols_rta <- lm(`Log Average GDP per capita, PPP` ~
`Green Symmetric Revealed Technological Advantage (RTA)`, data = rta)
pred_rta <- predict(ols_rta, newdata = rta, interval = "confidence")
rta$fitted   <- pred_rta[, "fit"]
rta$ci_lower <- pred_rta[, "lwr"]
rta$ci_upper <- pred_rta[, "upr"]
rta$log_total_patent <- log(rta[["Total Patent"]])
rta <- rta[order(rta$log_total_patent), ]
# Shared theme
shared_theme <- theme_minimal(base_size = 20) +
theme(
plot.title = element_text(size = 24, face = "bold"),
axis.title = element_text(size = 20),
axis.text  = element_text(size = 16),
legend.position = "bottom",
legend.box = "vertical",
legend.spacing.y = unit(0.2, "cm"),
legend.text = element_text(size = 15),
legend.title = element_text(size = 16),
legend.key.size = unit(0.6, "cm"),
plot.margin = margin(25, 15, 20, 10)
)
# --- Panel A ---
p_a <- ggplot(raa, aes(x = SRCA, y = log_average_gdppp)) +
geom_line(aes(y = fitted), colour = "grey50") +
geom_point(aes(colour = income_group, size = marker_size), alpha = 0.35) +
geom_vline(xintercept = 1, linetype = "dashed", colour = "red", alpha = 0.7) +
geom_text_repel(
data = subset(raa, Economy %in% c("United States", "China")),
aes(label = Economy),
size = 6, colour = "grey55", max.overlaps = Inf,
min.segment.length = 0.3, segment.color = "grey70", segment.alpha = 0.4,
force = 3, box.padding = 0.6, point.padding = 0.5,
direction = "both", seed = 42
) +
geom_text_repel(
data = subset(raa, !Economy %in% c("United States", "China")),
aes(label = Economy),
size = 6, colour = "grey55", max.overlaps = 5,
min.segment.length = 0.3, segment.color = "grey70", segment.alpha = 0.4,
force = 3, box.padding = 0.6, point.padding = 0.5,
direction = "both", seed = 42
) +
scale_colour_viridis_d() +
scale_size_continuous(
range = c(1, 12),
breaks = sort(unique(raa$marker_size)),
labels = size_labels
) +
labs(
title = "A: Green Revealed Academic Advantage\nvs GDP per capita",
x = "Green Revealed Academic\nAdvantage (RAA)",
y = "Log GDP per capita,\nPPP",
colour = "Income Group",
size = "Number of\npublications"
) +
shared_theme +
guides(
colour = guide_legend(order = 1, nrow = 2),
size   = guide_legend(order = 2, nrow = 3)
)
# --- Panel B ---
p_b <- ggplot(rta, aes(x = `Green Symmetric Revealed Technological Advantage (RTA)`,
y = `Log Average GDP per capita, PPP`)) +
geom_line(aes(y = fitted), colour = "grey50") +
geom_point(aes(colour = `Income group`, size = log_total_patent), alpha = 0.35) +
geom_vline(xintercept = 1, linetype = "dashed", colour = "red", alpha = 0.7) +
geom_text_repel(
data = subset(rta, Country %in% c("United States", "China")),
aes(label = Country),
size = 6, colour = "grey55", max.overlaps = Inf,
min.segment.length = 0.3, segment.color = "grey70", segment.alpha = 0.4,
force = 3, box.padding = 0.6, point.padding = 0.5,
direction = "both", seed = 42
) +
geom_text_repel(
data = subset(rta, !Country %in% c("United States", "China")),
aes(label = Country),
size = 6, colour = "grey55", max.overlaps = 5,
min.segment.length = 0.3, segment.color = "grey70", segment.alpha = 0.4,
force = 3, box.padding = 0.6, point.padding = 0.5,
direction = "both", seed = 42
) +
scale_colour_viridis_d() +
scale_size_continuous(
range = c(1, 12),
breaks = log(c(100, 1000, 10000, 100000, 1000000)),
labels = scales::comma(c(100, 1000, 10000, 100000, 1000000))
) +
labs(
title = "B: Green Revealed Technological Advantage\nvs GDP per capita",
x = "Green Symmetric Revealed\nTechnological Advantage (RTA)",
y = "Log GDP per capita,\nPPP",
colour = "Income Group",
size = "Total\nPatents"
) +
shared_theme +
guides(
colour = guide_legend(order = 1, nrow = 2),
size   = guide_legend(order = 2, nrow = 3)
)
# --- Combine side by side ---
p_a + p_b
